{
  "name": "Monefyi - Personal Finance",
  "short_name": "Monefyi",
  "description": "Kelola keuangan cerdas dengan AI. Offline-first, aman, dan mudah dipakai.",
  "start_url": "/app/?source=pwa",
  "scope": "/app/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone"],
  "orientation": "portrait",
  "background_color": "#0a0e1a",
  "theme_color": "#0a0e1a",
  "categories": ["finance", "productivity", "lifestyle"],
  "lang": "id-ID",
  "dir": "ltr",
  "prefer_related_applications": false,
  "icons": [
    {
      "src": "./icons/monefyi-logo.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "./icons/monefyi-logo.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "./icons/icon-192.svg",
      "sizes": "192x192",
      "type": "image/svg+xml"
    },
    {
      "src": "./icons/icon-512.svg",
      "sizes": "512x512",
      "type": "image/svg+xml"
    }
  ],
  "shortcuts": [
    {
      "name": "Tambah Transaksi",
      "short_name": "Tambah",
      "url": "/app/?action=add-transaction",
      "icons": [{ "src": "./icons/monefyi-logo.png", "sizes": "192x192" }]
    },
    {
      "name": "Scan Struk",
      "short_name": "Scan",
      "url": "/app/?action=scan-receipt",
      "icons": [{ "src": "./icons/monefyi-logo.png", "sizes": "192x192" }]
    }
  ],
  "share_target": {
    "action": "/app/?action=share-received",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  }
}
