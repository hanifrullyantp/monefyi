# Data source: planner (real Monefyi tables) | sandbox (rpp_* seed tables)
DATA_SOURCE=planner
PLANNER_ORG_ID=your-org-uuid

# Local PostgreSQL (Docker / brew) — sandbox mode only
# brew services start postgresql@16
# DATA_SOURCE=sandbox npm run db:setup && npm run dev
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/app_db

# Supabase remote (used when local Postgres unavailable)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# For one-time remote table setup (npm run db:remote-setup)
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=
