# --- Lokal (Vite) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
VITE_APP_ENV=development
VITE_DEV_DEMO_AUTH=false
# Dev only: skip email verification gate
VITE_SKIP_EMAIL_VERIFY=false

# Edge functions (Supabase dashboard — not used by React client directly)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=Monefyi <no-reply@monefyi.com>
# APP_URL=https://app.monefyi.com

# --- Vercel + Supabase integration (otomatis, tidak perlu duplikasi) ---
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
#
# Server-only (TIDAK dipakai app React client):
# POSTGRES_URL, POSTGRES_URL_NON_POOLING, POSTGRES_PASSWORD, SUPABASE_SERVICE_ROLE_KEY
